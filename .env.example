# ============================================================
# 客户运营中台 API - 环境变量配置示例
# ============================================================
# 使用说明：
# 1. 复制此文件为 .env
# 2. 运行 `python backend/scripts/generate_secrets.py` 生成安全密钥
# 3. 根据实际环境修改所有配置项
# 4. 切勿将 .env 文件提交到版本控制
# ============================================================

# ------------------------------------------------------------
# 应用配置
# ------------------------------------------------------------
# 环境：development | staging | production
APP_ENV=development

# 调试模式：true | false (生产环境必须为 false)
DEBUG=false

# 服务监听地址和端口
HOST=0.0.0.0
PORT=8000

# ------------------------------------------------------------
# 数据库配置 (必填)
# ------------------------------------------------------------
# PostgreSQL 连接字符串
# 格式：postgresql://用户名:密码@主机:端口/数据库名
# 生产环境请使用强密码，不要使用默认值
DATABASE_URL=postgresql://postgresql:your-secure-password@localhost:5432/customer_platform

# 数据库连接池大小
DATABASE_POOL_SIZE=5

# 最大溢出连接数
DATABASE_MAX_OVERFLOW=10

# SQL 日志：true | false (生产环境建议 false)
DATABASE_ECHO=false

# ------------------------------------------------------------
# JWT 认证配置 (必填)
# ------------------------------------------------------------
# JWT 密钥 - 必须使用至少 32 字符的随机字符串
# 生成方法：python backend/scripts/generate_secrets.py
# 切勿使用示例中的密钥！
JWT_SECRET=<请运行 generate_secrets.py 生成>

# JWT 算法 (推荐使用 HS256 或 RS256)
JWT_ALGORITHM=HS256

# Token 有效期 (分钟)，默认 24 小时
JWT_EXPIRE_MINUTES=1440

# Refresh Token 有效期 (天)
JWT_REFRESH_EXPIRE_DAYS=7

# ------------------------------------------------------------
# Webhook 配置 (必填)
# ------------------------------------------------------------
# Webhook 签名密钥 - 必须使用至少 32 字符的随机字符串
# 生成方法：python backend/scripts/generate_secrets.py
WEBHOOK_SECRET=<请运行 generate_secrets.py 生成>

# ------------------------------------------------------------
# Redis 配置 (可选，用于缓存和会话)
# ------------------------------------------------------------
# Redis 连接字符串
# 格式：redis://[:密码]@主机:端口/数据库
# REDIS_URL=redis://:your-redis-password@localhost:6379/0

# ------------------------------------------------------------
# CORS 跨域配置
# ------------------------------------------------------------
# 允许的源，多个用逗号分隔
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# 是否允许携带凭证
CORS_ALLOW_CREDENTIALS=true

# ------------------------------------------------------------
# 文件存储配置
# ------------------------------------------------------------
# 文件上传目录
FILE_STORAGE_PATH=./uploads

# 最大文件大小 (字节)，默认 10MB
MAX_FILE_SIZE=10485760

# ------------------------------------------------------------
# 邮件配置 (可选)
# ------------------------------------------------------------
# SMTP 服务器主机
# SMTP_HOST=smtp.company.com

# SMTP 端口
SMTP_PORT=587

# SMTP 用户名
# SMTP_USERNAME=noreply@company.com

# SMTP 密码 - 使用应用专用密码
# SMTP_PASSWORD=<你的邮件服务密码>

# ------------------------------------------------------------
# 外部 API 配置 (可选)
# ------------------------------------------------------------
# 外部 API 基础 URL
# EXTERNAL_API_BASE_URL=https://business-api.company.com

# 外部 API 访问令牌
# EXTERNAL_API_TOKEN=<你的 API 令牌>

# ============================================================
# 安全提醒
# ============================================================
# 1. 生产环境必须修改所有默认值
# 2. 使用强密码和随机密钥 (至少 32 字符)
# 3. 定期轮换密钥和密码
# 4. 不要将 .env 文件提交到 Git
# 5. 使用密钥管理服务 (如 AWS Secrets Manager) 管理生产密钥
# ============================================================
