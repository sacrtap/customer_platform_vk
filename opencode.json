{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [".opencode/plugins/graphify.js"],
  "agent": {
    "build": {
      "prompt": "{Graphify_Prompt.txt}",
      "permission": {
        "graphify_*": "allow"
      }
    },
    "plan": {
      "prompt": "{Graphify_Prompt.txt}",
      "permission": {
        "graphify_*": "allow"
      }
    }
  },
  "mcp": {
    "graphify": {
      "type": "local",
      "command": ["python", "-m", "graphify.serve", "graphify-out/graph.json"],
      "enabled": true
    }
  }
}
